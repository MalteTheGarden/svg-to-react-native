{
  "extends": "@svg-to-react-native/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["*", "../../packages/*"]
    },
    "rootDir": "../../"
  },
  "exclude": ["node_modules"],
  "files": ["../../packages/types/integrations/content.d.ts"],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../packages/types/index.d.ts",
    "../../packages/types/dependencies/*.d.ts"
  ]
}
