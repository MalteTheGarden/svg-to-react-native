{
  "name": "rn-svg-converter",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI tool to convert SVG files to React Native SVG components",
  "keywords": ["svg", "react-native", "svgr", "converter", "cli", "typescript"],
  "author": "",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "svg-to-react-native": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.2"
  }
}
